<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF9F6">

    <View
        android:id="@+id/detailHeader"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#014421"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtDetailTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Master Packing Manifesto"
        android:textColor="#FAF9F6"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/detailHeader"
        app:layout_constraintBottom_toBottomOf="@id/detailHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/detailHeader"
        app:layout_constraintBottom_toTopOf="@id/btnBackBase">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtDisplayArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#2F2F2F"
                android:textSize="15sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnBackBase"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_margin="16dp"
        android:backgroundTint="#014421"
        android:text="← Back To Base"
        android:textColor="#FAF9F6"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>