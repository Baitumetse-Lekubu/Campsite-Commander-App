<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF9F6"
    tools:context=".MainActivity">

    <View
        android:id="@+id/headerBackground"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#014421"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtDashboardTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gear Dashboard"
        android:textColor="#FAF9F6"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/headerBackground"
        app:layout_constraintBottom_toBottomOf="@id/headerBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardBackgroundColor="#D2CBB1"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/headerBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Packed Items"
                android:textColor="#2F2F2F"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/txtTotalCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#014421"
                android:textSize="48sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardSummary"
        app:layout_constraintBottom_toTopOf="@id/btnViewList">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add New Supply Item"
                android:textColor="#2F2F2F"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/edtItemName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Item Name (e.g. Cooking Pot)"
                android:background="@android:drawable/editbox_background"
                android:paddingLeft="10dp"
                android:inputType="textCapWords"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/edtCategory"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Category (e.g. Kitchen)"
                android:background="@android:drawable/editbox_background"
                android:paddingLeft="10dp"
                android:inputType="textCapWords"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/edtQuantity"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Quantity"
                android:background="@android:drawable/editbox_background"
                android:paddingLeft="10dp"
                android:inputType="number"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/edtComments"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Comments / Special Notes"
                android:background="@android:drawable/editbox_background"
                android:paddingLeft="10dp"
                android:inputType="text"
                android:layout_marginBottom="15dp"/>

            <Button
                android:id="@+id/btnAddItem"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:backgroundTint="#014421"
                android:text="Add Item to Supply List"
                android:textColor="#FAF9F6"
                android:textSize="16sp" />
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnViewList"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_margin="20dp"
        android:backgroundTint="#2F2F2F"
        android:text="View Detailed Gear List"
        android:textColor="#FAF9F6"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>